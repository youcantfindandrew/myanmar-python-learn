# ── Supabase (public — safe to expose in browser bundle) ──────────────────────
# Found in: Supabase dashboard → Project Settings → API → Project URL / anon key
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── Supabase service role (private — server-only, NEVER expose in browser) ────
# Found in: Supabase dashboard → Project Settings → API → service_role key
# Used only in src/lib/server/supabase-admin.ts for server-side sync writes.
# Without this, student progress sync will not work.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ── Groq AI (private — server-only, never sent to browser) ────────────────────
# Get a free key at: https://console.groq.com
# Used only in src/routes/api/ai/hint/+server.ts
# Leave blank to disable AI hints (app falls back to offline hints automatically)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
